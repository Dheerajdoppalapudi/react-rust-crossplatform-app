se": type=generic, visual="hexagon ring with a thick outline and inner small circles to suggest a sugar molecule", fill=#ffc9c9, label=\'Glucose\'\n  - "oxygen": type=generic, visual="two interlinked small blue circles labeled O₂ to represent an oxygen molecule", fill=#a5d8ff, label=\'O₂\''}], 'model': 'gpt-4.1', 'max_tokens': 8192}}
